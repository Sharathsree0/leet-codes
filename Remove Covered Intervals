/**
 * @param {number[][]} intervals
 * @return {number}
 */
var removeCoveredIntervals = function(intervals) {

    intervals.sort((a,b)=>{
        if(a[0]===b[0]){
            b[1]- a[1]
        }
        return a[0]- b[0]
    })
    let count =0;
    let max =0;
    for(let [start, end] of intervals){
        if(end> max){
            count++;
            max = end;
        }
    }
    return count;
};
